# ============================================================
# VietERP Platform — Environment Configuration
# Copy to .env and update values / Sao chep sang .env va cap nhat
# ============================================================

# ─── Application / Ung dung ─────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Database / Co so du lieu ────────────────────────────────
DATABASE_URL=postgresql://vierp:your-password@localhost:5432/vierp_dev

# ─── Redis / Cache ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── NATS JetStream / Event Bus ──────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Authentication / Xac thuc ───────────────────────────────
# Keycloak SSO
SSO_URL=http://localhost:8080
SSO_REALM=vierp
SSO_CLIENT_ID=vierp-app
SSO_CLIENT_SECRET=your-client-secret

# JWT (fallback)
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── API Gateway / Kong ──────────────────────────────────────
API_GATEWAY_URL=http://localhost:8000

# ─── AI Integration / Tich hop AI ────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Email / SMTP ────────────────────────────────────────────
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_FROM="VietERP <noreply@your-domain.com>"

# ─── Storage / Luu tru ───────────────────────────────────────
S3_BUCKET=vierp-files
S3_REGION=ap-southeast-1

# ─── Vietnamese Market / Thi truong Viet Nam ─────────────────
# VNPAY_TMN_CODE=your-vnpay-code
# MOMO_PARTNER_CODE=your-momo-code
# GHN_TOKEN=your-ghn-token

# ─── Branding Override / Tuy chinh thuong hieu ────────────────
# BRAND_NAME="Your Platform Name"
# BRAND_SHORT="YPN"
# BRAND_DOMAIN="your-domain.com"
