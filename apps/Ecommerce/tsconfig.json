{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@erp/shared": ["../../packages/shared/src"],
      "@erp/database": ["../../packages/database/src"],
      "@erp/events": ["../../packages/events/src"],
      "@erp/auth": ["../../packages/auth/src"],
      "@erp/master-data": ["../../packages/master-data/src"],
      "@erp/notifications": ["../../packages/notifications/src"]
    }
  },
  "include": ["src/**/*", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
