    "@erp/auth": "*",
    "@erp/events": "*",
    "@erp/feature-flags": "*",
    "@erp/master-data": "*",
    "@prisma/client": "^5.14.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0",
    "decimal.js": "^10.4.3",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.4.0",
    "prisma": "^5.14.0",
    "vitest": "^1.6.0"
  }
