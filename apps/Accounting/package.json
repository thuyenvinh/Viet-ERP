{
  "name": "erp-accounting",
  "version": "1.0.0",
  "private": true,
  "description": "ERP Accounting & Finance Module — VAS/IFRS Compliant",
  "scripts": {
    "dev": "next dev -p 3007",
    "build": "next build",
    "start": "next start -p 3007",
    "lint": "next lint",
